# ─────────────────────────────────────────────────────────────────────────
# prax-secrets-proxy environment  →  copy to `.env` (gitignored) and fill in.
#
# This is the ONE place the REAL API keys live. Run this proxy ISOLATED from the
# agent (its own container/user/host) so the agent's process can never read this
# file. The agent runs with only PLACEHOLDER keys + a base URL pointing here.
# NEVER commit `.env` (it's gitignored).
# ─────────────────────────────────────────────────────────────────────────

# The REAL model-provider keys (only this proxy holds them).
OPENAI_KEY=sk-real-openai-key-here
ANTHROPIC_KEY=sk-ant-real-anthropic-key-here

# Where the proxy listens (the agent points OPENAI_BASE_URL/ANTHROPIC_BASE_URL
# here). UNAUTHENTICATED by design — bind loopback or a private net only the
# agent can reach; reachability is the control.
PROXY_HOST=127.0.0.1
PROXY_PORT=8785

# Optional: route the OpenAI-compatible leg at a third-party (OpenRouter/DeepSeek)
# instead of api.openai.com. The Anthropic leg defaults to api.anthropic.com.
# PROXY_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# PROXY_ANTHROPIC_BASE_URL=https://api.anthropic.com
# PROXY_ANTHROPIC_VERSION=2023-06-01

# Optional: write an audit line per proxied call (method/provider/path/status/size
# — NEVER the key or body) to this file, for after-the-fact review.
# PROXY_AUDIT_LOG=/var/log/prax-secrets-proxy.log

# Optional: whole-request timeout (seconds) and a different env file to load.
# PROXY_TIMEOUT_S=600
# PROXY_ENV_FILE=.env
